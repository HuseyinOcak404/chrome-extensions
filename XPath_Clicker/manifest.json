{
  "manifest_version": 3,
  "name": "XPath Clicker",
  "version": "1.0",
  "permissions": ["tabs","scripting", "storage", "activeTab", "sidePanel","alarms"],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_title": "XPath Clicker",
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "side_panel": {
    "default_path": "main.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}