{
  "manifest_version": 3,
  "name": "Toplu Dosya İndirici",
  "version": "1.0",
  "description": "Tabloya göre dosyaları klasörlere ayırarak indirir.",
  "permissions": ["downloads", "activeTab", "sidePanel"],
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Toplu İndirici",
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
